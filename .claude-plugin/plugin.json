{
  "name": "memory-layer-core",
  "version": "4.1.0",
  "description": "Your AI remembers everything between sessions. Context, tasks, goals, and a handoff note persist automatically — so every new session picks up exactly where the last one left off. Free to start.",
  "author": {
    "name": "Rabbithole LLC"
  },
  "homepage": "https://memorylayer.pro",
  "keywords": [
    "memory",
    "persistent-context",
    "session-management",
    "supabase-sync",
    "agent-modules",
    "mls-core",
    "cloud-sync",
    "mcp-server"
  ],
  "license": "UNLICENSED",
  "mcp_server": {
    "package": "@memorylayer/mcp-server",
    "description": "MCP server alternative to this plugin. Works in Claude Code, Cursor, Windsurf, and any MCP-compatible AI tool. Exposes 15 tools covering sessions, push/pull, file storage, semantic search, agents, and team management.",
    "install": {
      "claude_code": {
        "settings_file": ".claude/settings.json",
        "config": {
          "mcpServers": {
            "mls-core": {
              "command": "npx",
              "args": ["-y", "@memorylayer/mcp-server"],
              "env": {
                "MLS_API_KEY": "<your-api-key>"
              }
            }
          }
        }
      },
      "cursor": {
        "settings_file": ".cursor/mcp.json",
        "config": {
          "mcpServers": {
            "mls-core": {
              "command": "npx",
              "args": ["-y", "@memorylayer/mcp-server"],
              "env": {
                "MLS_API_KEY": "<your-api-key>"
              }
            }
          }
        }
      },
      "windsurf": {
        "settings_file": "~/.codeium/windsurf/mcp_config.json",
        "config": {
          "mcpServers": {
            "mls-core": {
              "command": "npx",
              "args": ["-y", "@memorylayer/mcp-server"],
              "env": {
                "MLS_API_KEY": "<your-api-key>"
              }
            }
          }
        }
      }
    },
    "api_key_location": ".mls/config.json → supabase.api_key",
    "api_key_dashboard": "https://memorylayer.pro/dashboard"
  }
}
